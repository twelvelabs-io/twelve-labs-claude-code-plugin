{
  "name": "dev-hud",
  "description": "Always-visible Claude Code HUD showing the Linear ticket, PR, worktree, and dirty/ahead branch state with clickable links into Linear and Cursor.",
  "version": "0.1.0",
  "author": {
    "name": "TwelveLabs"
  },
  "homepage": "https://github.com/twelvelabs-io/twelve-labs-claude-code-plugin/tree/main/dev-hud",
  "repository": "https://github.com/twelvelabs-io/twelve-labs-claude-code-plugin",
  "license": "MIT",
  "keywords": ["statusline", "hud", "linear", "git", "worktree", "productivity"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/activate.js\"",
            "timeout": 5,
            "statusMessage": "Checking Dev-HUD wiring..."
          }
        ]
      }
    ]
  }
}
